# Port the tRPC/Express server listens on
PORT=4000

# Postgres connection string. Managed providers (e.g. DigitalOcean) require TLS.
# Local dev against a plain Postgres can add DATABASE_SSL=false to skip TLS.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/quaketrack
# DATABASE_SSL=false

# Web Push (VAPID) keys — generate with: npm run gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: or https: contact URI required by the Web Push spec
VAPID_SUBJECT=mailto:you@example.com

# How often (ms) the background poller checks USGS for new quakes
POLL_INTERVAL_MS=60000
# Server-side magnitude floor for the notification poller
POLL_MIN_MAGNITUDE=2
